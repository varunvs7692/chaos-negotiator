# Core runtime
ENVIRONMENT=production
PORT=8000
LOG_LEVEL=INFO
CN_ENABLE_TUNING=true
CN_TUNING_INTERVAL_SEC=300

# Optional API protection
API_AUTH_KEY=
GITHUB_WEBHOOK_SECRET=

# Azure OpenAI
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
OPENAI_API_VERSION=2024-02-15-preview

# Azure live telemetry
AZURE_MONITOR_WORKSPACE_ID=
CN_DASHBOARD_SERVICE_NAME=chaos-negotiator
CN_DEPLOYMENT_HISTORY_SERVICE_NAME=chaos-negotiator
CONTAINER_APP_NAME=chaos-negotiator

# Local persistence
CN_HISTORY_DB=deployment_history.db
CN_APPROVAL_DB=deployment_approvals.db

# Optional monitoring
APPINSIGHTS_INSTRUMENTATIONKEY=
